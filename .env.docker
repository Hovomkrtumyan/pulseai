# Docker deployment environment variables
# Copy this to .env on the server and fill in your values

DEEPSEEK_API_KEY=your_deepseek_api_key_here
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pulseai
JWT_SECRET=change-this-to-a-random-secret-string
NODE_ENV=production
PORT=3000
BASE_PATH=/PulseAi
